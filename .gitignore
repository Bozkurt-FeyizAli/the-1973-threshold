## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# dotenv environment variables file
.env

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

.DS_STORE

/dist/
/bazel-out
/integration/bazel/bazel-*
*.log
node_modules/
modules/ssr-benchmarks/node_modules/

# Include when developing application packages.
pubspec.lock
.c9
.idea/
.devcontainer/*
!.devcontainer/README.md
!.devcontainer/recommended-devcontainer.json
!.devcontainer/recommended-Dockerfile
.settings/
.vscode/settings.json
*.swo
*.swp
modules/.settings
modules/.vscode
.vimrc
.nvimrc

# Don't check in secret files
*secret.js

# Ignore npm/yarn debug log
npm-debug.log
yarn-error.log

# build-analytics
.build-analytics

# rollup-test output
/modules/rollup-test/dist/

# User specific bazel settings
.bazelrc.user

# User specific ng-dev settings
.ng-dev.user*

.notes.md
baseline.json

# Ignore .history for the xyz.local-history VSCode extension
.history

# Husky
.husky/_

# Ignore cache created with the Angular CLI.
.angular/

# pnpm store
.pnpm-store

# requirements
**/requirements/*
backend/system\ requirements/*
frontend/system\ requirements/*
kimi/*
frontend/.DS_STORE

frontend/dist/
frontend/bazel-out
frontend/integration/bazel/bazel-*
frontend/*.log
frontend/node_modules/
frontend/modules/ssr-benchmarks/node_modules/

# Include when developing application packages.
frontend/pubspec.lock
frontend/.c9
frontend/.idea/
frontend/.devcontainer/*
frontend/!.devcontainer/README.md
frontend/!.devcontainer/recommended-devcontainer.json
frontend/!.devcontainer/recommended-Dockerfile
frontend/.settings/
frontend/.vscode/settings.json
frontend/*.swo
frontend/*.swp
frontend/modules/.settings
frontend/modules/.vscode
frontend/.vimrc
frontend/.nvimrc

# Don't check in secret files
frontend/*secret.js

# Ignore npm/yarn debug log
frontend/npm-debug.log
frontend/yarn-error.log

# build-analytics
frontend/.build-analytics

# rollup-test output
frontend/modules/rollup-test/dist/

# User specific bazel settings
frontend/.bazelrc.user

# User specific ng-dev settings
frontend/.ng-dev.user*

frontend/.notes.md
frontend/baseline.json

# Ignore .history for the xyz.local-history VSCode extension
frontend/.history

# Husky
frontend/.husky/_

# Ignore cache created with the Angular CLI.
frontend/.angular/

# pnpm store
frontend/.pnpm-store